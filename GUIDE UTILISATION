3. FEniCS + preCICE
----------------------------
----------------------------
### charger l'environnement 

module load coupling/precice-fenics
conda activate fenics-env

### script python type : 

from fenics import *
import fenicsprecice

# Initialisation
participant = fenicsprecice.Adapter(
    config_file="precice-config.xml",
    participant_name="Solid",
    mesh_name="SolidMesh"
)

# Définition du problème
mesh = UnitSquareMesh(10, 10)
V = FunctionSpace(mesh, 'P', 1)
u = Function(V)

# Boucle de couplage
while participant.is_coupling_ongoing():
    data = participant.read_data()
    # Résoudre votre problème
    # ...
    participant.write_data(data)
    participant.advance()

### lancer 
python3 mon_script.py

### dasactiver l'environnement
conda deactivate

