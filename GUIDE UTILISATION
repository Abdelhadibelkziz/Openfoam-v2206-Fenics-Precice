5.vérifications : 
-----------------
-----------------
### OpenFOAM + preCICE :

module load coupling/precice-openfoam
echo $WM_PROJECT_VERSION      # v2206
pkg-config --modversion libprecice  # 3.1.2
ls $FOAM_USER_LIBBIN/libpreciceAdapterFunctionObject.so

### FEniCS + preCICE :

module load coupling/precice-fenics
conda activate fenics-env
python -c "import fenicsprecice; print(fenicsprecice.__version__)"  # 2.3.0
conda deactivate

